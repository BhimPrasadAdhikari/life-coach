# Copy this file to .env and fill in your API keys
# See docs/API_SETUP_GUIDE.md for detailed instructions

# GROQ (Required)
# Get your key at: https://console.groq.com/keys
# Used for: LLM (Llama 3.1/3.3), Vision (Llama 4 Scout), STT (Whisper)
GROQ_API_KEY=your_groq_api_key_here

# GEMINI (Optional — used as automatic fallback when Groq hits rate limits)
# Also selectable directly as a model from the chat UI
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ELEVENLABS (Required)
# Get your key at: https://elevenlabs.io → Profile → API Key
# Used for: Text-to-Speech voice responses
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# HUGGINGFACE (Required)
# Get your token at: https://huggingface.co/settings/tokens
# Used for: Image generation with Stable Diffusion XL
HF_TOKEN=your_huggingface_token_here

# QDRANT (Required)
# Set up at: https://cloud.qdrant.io
# Used for: Long-term memory storage (Vector Database)
QDRANT_URL=https://your-cluster-id.region.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# CHAINLIT AUTHENTICATION (Optional - enables conversation history)
# Generate with: chainlit create-secret
# Used for: Secure session tokens and enabling conversation history sidebar
CHAINLIT_AUTH_SECRET=your_chainlit_auth_secret_here

# Login credentials (Optional - defaults to user/password)
AUTH_USERNAME=user
AUTH_PASSWORD=your_secure_password_here

# LANGSMITH TRACING (Optional)
# Get your key at: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=whatsapp_agent
